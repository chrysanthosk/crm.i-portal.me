APP_NAME="CRM Dev"
APP_ENV=development
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=https://crm-dev.i-portal.me

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=crm-db
DB_PORT=3306
DB_DATABASE=crm_dev_i_portal_me
DB_USERNAME=crm_dev_i_portal_me
# Required — set a strong unique password, also exported for docker-compose
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Required — separate root password for MySQL container (used in docker-compose healthcheck)
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Set to true in production to encrypt session data at rest
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Seeder credentials (override before running db:seed in production) ---
# These set the initial admin account. Change before seeding any real environment.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Inventory ---
# Quantity below which a product is flagged as low stock
INVENTORY_LOW_STOCK_THRESHOLD=5
