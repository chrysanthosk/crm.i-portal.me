APP_NAME="CRM Dev"
APP_ENV=development
APP_KEY=base64:GENERATE_AND_REPLACE_ME
# WARNING: set APP_DEBUG=false in production to avoid leaking stack traces
APP_DEBUG=true
APP_URL=https://crm-dev.i-portal.me

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=crm-db
DB_PORT=3306
DB_DATABASE=crm_dev_i_portal_me
DB_USERNAME=crm_dev_i_portal_me
# Required — set a strong unique password, also exported for docker-compose
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Required — separate root password for MySQL container (used in docker-compose healthcheck)
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_PASSWORD=CHANGE_ME_DEV_DB_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# For production use Redis: QUEUE_CONNECTION=redis
QUEUE_CONNECTION=database

# For production use Redis: CACHE_STORE=redis
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Initial admin credentials — used only by InitialSetupSeeder
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
